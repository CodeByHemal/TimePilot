<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TimePilot" parent="Theme.Material3.Light.NoActionBar">
        <!-- Material3 Color System -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryContainer">@color/purple_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/purple_dark</item>
        <item name="colorSecondary">@color/purple_primary</item>
        <item name="colorSecondaryContainer">@color/purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSecondaryContainer">@color/purple_dark</item>
        <item name="colorSurface">@color/bg_main</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/purple_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/urgent_red</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.TimePilot" parent="Base.Theme.TimePilot" />

    <!-- Splash Screen Theme -->
    <style name="Theme.TimePilot.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Disable Android 12+ default icon splash -->
    </style>
</resources>