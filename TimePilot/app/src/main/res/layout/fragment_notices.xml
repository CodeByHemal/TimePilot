<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/noticesScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — Avatar  |  Brand Name  |  Bell              -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/noticesTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- User Avatar (Material3 ShapeableImageView) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/noticesImgAvatar"
                android:layout_width="@dimen/avatar_size"
                android:layout_height="@dimen/avatar_size"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

            <!-- Brand name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/noticesTvBrand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/scholarly_atelier"
                android:textColor="@color/purple_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Notification bell (Material3 IconButton) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/noticesBtnNotification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/alert"
                app:icon="@drawable/ic_notification"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

        </LinearLayout>
        <!-- ===================================================== -->
        <!-- FILTER CHIPS — Notices | Timetable                    -->
        <!-- ===================================================== -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/noticesFilterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            app:selectionRequired="true"
            app:singleSelection="true">

            <!-- Notices — selected by default (dark chip) -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterNotices"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/filter_notices"
                android:textColor="@color/chip_selected_text"
                android:textStyle="bold"
                app:checkedIconEnabled="false"
                app:chipBackgroundColor="@color/chip_selected_bg"
                app:chipCornerRadius="@dimen/radius_sm"
                app:chipMinHeight="36dp"
                app:chipStrokeWidth="0dp" />

            <!-- Timetable — unselected -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterTimetable"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_timetable"
                android:textColor="@color/chip_unselected_text"
                app:checkedIconEnabled="false"
                app:chipBackgroundColor="@color/chip_unselected_bg"
                app:chipCornerRadius="@dimen/radius_sm"
                app:chipMinHeight="36dp"
                app:chipStrokeWidth="0dp" />

        </com.google.android.material.chip.ChipGroup>

        <!-- ===================================================== -->
        <!-- NOTICE CARD 1 — Faculty of Architecture               -->
        <!-- ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotice1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            app:cardBackgroundColor="@color/notice_card_bg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <!-- ────── Header: Avatar + Name + Time + Menu ────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Purple circle avatar with building icon -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_notice_avatar">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/notice_faculty_name"
                            android:src="@drawable/ic_building" />

                    </FrameLayout>

                    <!-- Name + timestamp -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvNotice1FacultyName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notice_faculty_name"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvNotice1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notice_faculty_time"
                            android:textColor="@color/notice_time_text"
                            android:textSize="@dimen/text_badge"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                    <!-- 3-dot menu (Material3 IconButton) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNotice1Menu"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/more_options"
                        app:icon="@drawable/ic_more_vert"
                        app:iconSize="20dp"
                        app:iconTint="@color/text_secondary" />

                </LinearLayout>

                <!-- ────── Notice body text ──────────────────────── -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvNotice1Text1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/notice_faculty_text_1"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body"
                    android:lineSpacingExtra="3dp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvNotice1Text2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/notice_faculty_text_2"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body"
                    android:lineSpacingExtra="3dp" />

                <!-- ────── Illustration Card (Dark themed) ───────── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNotice1Image"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginTop="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/notice_image_bg"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <!-- Architectural illustration overlay -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/notice_faculty_name"
                        android:scaleType="centerInside"
                        android:src="@drawable/notice_illustration" />

                </com.google.android.material.card.MaterialCardView>

                <!-- ────── Tag Chips: EVENT + URGENT ──────────────── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal">

                    <!-- EVENT chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipNotice1Event"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/chip_event"
                        android:textColor="@color/chip_event_text"
                        android:textSize="@dimen/text_badge"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/chip_event_bg"
                        app:chipCornerRadius="@dimen/radius_sm"
                        app:chipMinHeight="26dp"
                        app:chipMinTouchTargetSize="0dp"
                        app:chipStrokeWidth="0dp"
                        android:letterSpacing="0.06" />

                    <!-- URGENT chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipNotice1Urgent"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:letterSpacing="0.06"
                        android:text="@string/chip_urgent"
                        android:textColor="@color/chip_urgent_text"
                        android:textSize="@dimen/text_badge"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/chip_urgent_bg"
                        app:chipCornerRadius="@dimen/radius_sm"
                        app:chipMinHeight="26dp"
                        app:chipMinTouchTargetSize="0dp"
                        app:chipStrokeWidth="0dp"
                        tools:ignore="TouchTargetSizeCheck" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ===================================================== -->
        <!-- NOTICE CARD 2 — Registrar's Office                    -->
        <!-- ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotice2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/notice_card_bg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:paddingBottom="10dp">

                <!-- ────── Header: Avatar + Name + Time ──────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Purple circle avatar with document icon -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_notice_avatar">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/notice_registrar_name"
                            android:src="@drawable/ic_document" />

                    </FrameLayout>

                    <!-- Name + timestamp -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvNotice2FacultyName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notice_registrar_name"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvNotice2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notice_registrar_time"
                            android:textColor="@color/notice_time_text"
                            android:textSize="@dimen/text_badge"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ────── Notice body text ──────────────────────── -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvNotice2Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/notice_registrar_text"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
