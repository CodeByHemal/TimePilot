<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registerStudentScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:paddingBottom="10dp"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — ← Back | Brand | Bell | Avatar              -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/topBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Back button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/go_back"
                app:icon="@drawable/ic_arrow_back"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

            <!-- Brand name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBrandName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/faculty_brand"
                android:textColor="@color/brand_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Notification Bell -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/alert"
                app:icon="@drawable/ic_notification"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

            <!-- User Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- HERO SECTION — "ENROLMENT"                             -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_student_label"
                android:textColor="@color/purple_primary"
                android:textSize="@dimen/text_badge"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvRegisterTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:fontFamily="sans-serif-black"
                android:text="@string/register_student_title"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- FORM CARD — Registration Form                          -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_faculty_form_card"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingTop="@dimen/spacing_xxl"
            android:paddingEnd="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Student Name field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStudentName"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/student_name_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStudentName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Student Email field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStudentEmail"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="@string/student_email_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary"
                app:startIconDrawable="@drawable/ic_notification"
                app:startIconTint="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStudentEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>
            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="@string/student_password_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary"
                app:startIconDrawable="@drawable/ic_visibility"
                app:startIconTint="@color/purple_primary"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Roll Number field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRollNumber"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="@string/student_roll_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary"
                app:startIconDrawable="@drawable/ic_school"
                app:startIconTint="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRollNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- Register Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/register_btn_text"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="16dp"
                app:rippleColor="@color/purple_dark" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
