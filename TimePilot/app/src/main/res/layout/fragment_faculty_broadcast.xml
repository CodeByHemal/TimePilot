<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/broadcastScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — Avatar | "Scholarly Atelier" | Bell          -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/topBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Faculty Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="@dimen/avatar_size"
                android:layout_height="@dimen/avatar_size"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

            <!-- Brand name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBrandName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/faculty_brand"
                android:textColor="@color/brand_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Notification Bell -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/alert"
                app:icon="@drawable/ic_notification"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- HERO SECTION — "FACULTY COMMUNICATIONS"                -->
        <!--                 "Broadcast" + "New Notice" (purple)     -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:orientation="vertical">

            <!-- "Broadcast" — dark -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBroadcastLine1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:fontFamily="sans-serif-black"
                android:text="@string/broadcast_hero_line1"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />

            <!-- "New Notice" — purple accent -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBroadcastLine2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/broadcast_hero_line2"
                android:textColor="@color/purple_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- BROADCAST MESSAGE FORM CARD                            -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/messageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_faculty_form_card"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingTop="@dimen/spacing_xxl"
            android:paddingEnd="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Broadcast Message text area -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBroadcastMessage"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/broadcast_message_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBroadcastMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:text="@string/broadcast_message_hint"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_body"
                    android:lineSpacingExtra="4dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Upload attachment area -->
            <LinearLayout
                android:id="@+id/uploadArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_upload_dashed"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <!-- Cloud upload icon -->
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cloud_upload"
                    android:contentDescription="@string/upload_attachment" />

                <!-- Upload text -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvUploadText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/upload_attachment"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <!-- File types caption -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvUploadCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/upload_file_types"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- BROADCAST NOW BUTTON — Full width purple               -->
        <!-- ===================================================== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBroadcastNow"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="@string/broadcast_now_btn"
            android:textColor="@color/broadcast_btn_text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/broadcast_btn_bg"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_broadcast"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            app:iconTint="@color/broadcast_btn_text"
            app:rippleColor="@color/purple_dark" />

        <!-- Legal disclaimer text -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvLegalDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="@string/broadcast_legal"
            android:textColor="@color/broadcast_legal_text"
            android:textSize="@dimen/text_caption"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
