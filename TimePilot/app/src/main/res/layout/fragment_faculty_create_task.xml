<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/createTaskScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — ← Back | "Scholarly Atelier" | Bell | Avatar -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/topBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Back button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/go_back"
                app:icon="@drawable/ic_arrow_back"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

            <!-- Brand name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBrandName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/faculty_brand"
                android:textColor="@color/brand_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Notification Bell -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/alert"
                app:icon="@drawable/ic_notification"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

            <!-- User Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- HERO SECTION — "FACULTY PORTAL" + "Create New Task"    -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:orientation="vertical">

            <!-- Create New Task title -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvCreateTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:fontFamily="sans-serif-black"
                android:text="@string/create_task_title"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvCreateTaskSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/create_task_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- FORM CARD — Lavender surface background                -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:background="@drawable/bg_faculty_form_card"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingTop="@dimen/spacing_xxl"
            android:paddingEnd="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Task Title field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTaskTitle"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/task_title_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTaskTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/task_title_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Class / Batch dropdown (Exposed Dropdown Menu) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilClassBatch"
                style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="@string/class_batch_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary"
                app:endIconTint="@color/text_secondary">

                <AutoCompleteTextView
                    android:id="@+id/actvClassBatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="@string/class_batch_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    tools:ignore="LabelFor" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Set Deadline field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDeadline"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="@string/set_deadline_label"
                app:boxBackgroundColor="@color/bg_card"
                app:boxCornerRadiusTopStart="@dimen/radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                app:hintTextColor="@color/text_hint"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/purple_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:text="@string/deadline_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Priority Level -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPriorityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/priority_level_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <!-- Priority Chips Row -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:singleSelection="true"
                app:selectionRequired="true">

                <!-- ! High -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHigh"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/priority_high_label"
                    android:textColor="@color/priority_high_text"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body"
                    app:chipBackgroundColor="@color/priority_high_bg"
                    app:chipCornerRadius="20dp"
                    app:chipStrokeWidth="0dp"
                    app:chipIcon="@drawable/ic_priority_dot"
                    app:chipIconTint="@color/priority_high_text"
                    app:chipIconSize="14dp" />

                <!-- ≡ Medium -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/priority_medium_label"
                    android:textColor="@color/priority_medium_text"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body"
                    app:chipBackgroundColor="@color/priority_medium_bg"
                    app:chipCornerRadius="20dp"
                    app:chipStrokeWidth="0dp"
                    app:chipIcon="@drawable/ic_notes"
                    app:chipIconTint="@color/priority_medium_text"
                    app:chipIconSize="14dp" />

                <!-- ↓ Low -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLow"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/priority_low_label"
                    android:textColor="@color/priority_low_text"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body"
                    app:chipBackgroundColor="@color/priority_low_bg"
                    app:chipCornerRadius="20dp"
                    app:chipStrokeWidth="0dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- SUBTASK BUILDER SECTION                                -->
        <!-- ===================================================== -->

        <!-- Section header: "Subtask Builder" + "3 Added" badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtaskBuilderLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/subtask_builder_label"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section_title"
                android:textStyle="bold" />

            <!-- 3 Added badge -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtaskBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_subtask_badge"
                android:text="@string/subtask_added_badge"
                android:textColor="@color/subtask_badge_text"
                android:textSize="@dimen/text_badge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Subtask input field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSubtaskInput"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:boxBackgroundColor="@color/bg_card"
            app:boxCornerRadiusTopStart="@dimen/radius_sm"
            app:boxCornerRadiusTopEnd="@dimen/radius_sm"
            app:boxCornerRadiusBottomStart="@dimen/radius_sm"
            app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
            app:hintEnabled="false"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeColor="@color/purple_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSubtaskInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/subtask_input_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- + Add button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSubtask"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/add_subtask"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            app:backgroundTint="@color/purple_primary"
            app:cornerRadius="@dimen/radius_sm"
            app:rippleColor="@color/purple_light" />

        <!-- ===================================================== -->
        <!-- SUBTASK LIST — Checkboxes                              -->
        <!-- ===================================================== -->

        <!-- Subtask 1 (checked) -->
        <LinearLayout
            android:id="@+id/subtask1Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbSubtask1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:buttonTint="@color/subtask_checkbox_done" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtask1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/subtask_1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_card_title" />

        </LinearLayout>

        <!-- Subtask 2 (unchecked) -->
        <LinearLayout
            android:id="@+id/subtask2Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbSubtask2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                app:buttonTint="@color/subtask_checkbox_undone" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtask2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/subtask_2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_card_title" />

        </LinearLayout>

        <!-- Subtask 3 (unchecked) -->
        <LinearLayout
            android:id="@+id/subtask3Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbSubtask3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                app:buttonTint="@color/subtask_checkbox_undone" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtask3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/subtask_3"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_card_title" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- ASSIGN TASK TO BATCH BUTTON — Full width purple        -->
        <!-- ===================================================== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAssignTask"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="@string/assign_task_btn"
            android:textColor="@color/assign_btn_text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/assign_btn_bg"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_assign_check"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            app:iconTint="@color/assign_btn_text"
            app:rippleColor="@color/purple_dark" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
