<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/facultyHomeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingEnd="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- ===================================================== -->
            <!-- TOP BAR — Avatar  |  "Scholarly Atelier"  |  Bell      -->
            <!-- ===================================================== -->
            <LinearLayout
                android:id="@+id/topBarLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Faculty Avatar -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgFacultyAvatar"
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:scaleType="centerCrop"
                    android:src="@drawable/user_avatar"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="@color/purple_light"
                    app:strokeWidth="2dp" />

                <!-- Brand name -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvFacultyBrand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:text="@string/faculty_brand"
                    android:textColor="@color/brand_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Notification Bell -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFacultyNotification"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/alert"
                    app:icon="@drawable/ic_notification"
                    app:iconSize="22dp"
                    app:iconTint="@color/text_primary" />

            </LinearLayout>

            <!-- ===================================================== -->
            <!-- VELOCITY METRICS CARD — Purple gradient                -->
            <!-- ===================================================== -->
            <LinearLayout
                android:id="@+id/metricsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:background="@drawable/bg_faculty_metrics_card"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_xxl"
                android:paddingTop="@dimen/spacing_xl"
                android:paddingEnd="@dimen/spacing_xxl"
                android:paddingBottom="@dimen/spacing_xxl">

                <!-- "Student Completion" title -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvStudentCompletion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/student_completion"
                    android:textColor="@color/faculty_metrics_text"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

                <!-- 84% + AVG. RATE row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical|start"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvCompletionPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/completion_percentage"
                        android:textColor="@color/faculty_metrics_text"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvAvgRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Student"
                        android:textColor="@color/faculty_metrics_label"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

                <!-- Subject scores row: 3 circles + labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <!-- Subject 1: Advanced Logic 92% -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_faculty_subject_circle">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/subject_adv_logic_pct"
                                android:textColor="@color/faculty_metrics_text"
                                android:textSize="@dimen/text_card_title"
                                android:textStyle="bold" />

                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center"
                            android:text="@string/subject_adv_logic"
                            android:textColor="@color/faculty_metrics_label"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="1dp" />

                    </LinearLayout>

                    <!-- Subject 2: Digital Ethics 76% -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_faculty_subject_circle">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/subject_digital_ethics_pct"
                                android:textColor="@color/faculty_metrics_text"
                                android:textSize="@dimen/text_card_title"
                                android:textStyle="bold" />

                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center"
                            android:text="@string/subject_digital_ethics"
                            android:textColor="@color/faculty_metrics_label"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="1dp" />

                    </LinearLayout>

                    <!-- Subject 3: UI Studio 84% -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_faculty_subject_circle">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/subject_ui_studio_pct"
                                android:textColor="@color/faculty_metrics_text"
                                android:textSize="@dimen/text_card_title"
                                android:textStyle="bold" />

                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:gravity="center"
                            android:text="@string/subject_ui_studio"
                            android:textColor="@color/faculty_metrics_label"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="1dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===================================================== -->
            <!-- RECENT BROADCASTS SECTION                              -->
            <!-- ===================================================== -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvRecentBroadcastsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/recent_broadcasts"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_section_title"
                android:textStyle="bold" />

            <!-- Broadcast 2: Lab Reschedule -->
            <LinearLayout
                android:id="@+id/broadcast2Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal">

                <!-- Purple circle avatar -->
                <FrameLayout
                    android:layout_width="@dimen/avatar_size"
                    android:layout_height="@dimen/avatar_size"
                    android:background="@drawable/bg_faculty_broadcast_avatar">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_school"
                        android:contentDescription="@string/broadcast_2_title"
                        app:tint="@color/white" />

                </FrameLayout>

                <!-- Broadcast content -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Title + Time row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvBroadcast2Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/broadcast_2_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvBroadcast2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/broadcast_2_time"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_caption" />

                    </LinearLayout>

                    <!-- Body text -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvBroadcast2Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/broadcast_2_body"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body" />

                    <!-- Chip tag -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBroadcast2"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/broadcast_2_chip"
                        android:textColor="@color/faculty_broadcast_chip_text"
                        android:textSize="@dimen/text_badge"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/faculty_broadcast_chip_bg"
                        app:chipCornerRadius="@dimen/radius_sm"
                        app:chipMinHeight="24dp"
                        app:chipMinTouchTargetSize="0dp"
                        app:chipStrokeWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Add Student FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/spacing_xl"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/add_student_fab_desc"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/faculty_fab_bg"
        app:rippleColor="@color/purple_dark"
        app:tint="@color/faculty_fab_icon"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
