<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/taskScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — Avatar  |  App Name  |  Bell                -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/taskTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/taskImgAvatar"
                android:layout_width="@dimen/avatar_size"
                android:layout_height="@dimen/avatar_size"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/taskTvBrand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/scholarly_atelier"
                android:textColor="@color/purple_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/taskBtnNotification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/alert"
                app:icon="@drawable/ic_notification"
                app:iconSize="22dp"
                app:iconTint="@color/text_primary" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- HERO SECTION — "Campus Companion"                     -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/taskHeroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/taskTvHeroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/task_hero_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_title_hero"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/taskTvHeroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/task_hero_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- FILTER CHIPS (Material3 ChipGroup)                    -->
        <!-- ===================================================== -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/taskFilterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterHigh"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/filter_high"
                android:textColor="@color/chip_selected_text"
                android:textStyle="bold"
                app:checkedIconEnabled="false"
                app:chipBackgroundColor="@color/chip_selected_bg"
                app:chipCornerRadius="@dimen/radius_sm"
                app:chipIcon="@drawable/ic_priority_dot"
                app:chipIconEnabled="true"
                app:chipIconSize="6dp"
                app:chipIconTint="@color/white"
                app:chipMinHeight="36dp"
                app:chipStartPadding="12dp"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterMedium"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_medium"
                android:textColor="@color/chip_unselected_text"
                app:checkedIconEnabled="false"
                app:chipBackgroundColor="@color/chip_unselected_bg"
                app:chipCornerRadius="@dimen/radius_sm"
                app:chipMinHeight="36dp"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterLow"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_low"
                android:textColor="@color/chip_unselected_text"
                app:checkedIconEnabled="false"
                app:chipBackgroundColor="@color/chip_unselected_bg"
                app:chipCornerRadius="@dimen/radius_sm"
                app:chipMinHeight="36dp"
                app:chipStrokeWidth="0dp" />

        </com.google.android.material.chip.ChipGroup>

        <!-- ===================================================== -->
        <!-- TASK CARD 1 — Java Assignment 3 (Critical Priority)   -->
        <!-- ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTaskBoard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:id="@+id/taskBoard1AccentBar"
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="@color/urgent_red" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvCriticalPriority"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:letterSpacing="0.08"
                            android:text="@string/critical_priority"
                            android:textColor="@color/urgent_red"
                            android:textSize="@dimen/text_badge"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvTaskBoard1Date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/task_board_1_date"
                            android:textColor="@color/urgent_red"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvTaskBoard1Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/task_board_1_name"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/instructor_label"
                            android:src="@drawable/ic_person" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvTaskBoard1Instructor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:text="@string/task_board_1_instructor"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/tvCompletionLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.06"
                                    android:text="@string/completion_status"
                                    android:textColor="@color/text_hint"
                                    android:textSize="@dimen/text_badge"
                                    android:textStyle="bold" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/tvTaskBoard1Completion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:text="@string/task_board_1_completion"
                                    android:textColor="@color/text_primary"
                                    android:textSize="@dimen/text_body"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressTaskBoard1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:layout_marginEnd="@dimen/spacing_lg"
                                android:progress="75"
                                app:indicatorColor="@color/purple_primary"
                                app:trackColor="@color/progress_track"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="8dp" />

                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_grade_badge">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.05"
                                    android:text="@string/grade_label"
                                    android:textColor="@color/text_hint"
                                    android:textSize="7sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/tvTaskBoard1Grade"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/task_board_1_grade"
                                    android:textColor="@color/grade_badge_text"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </FrameLayout>

                    </LinearLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvMilestonesLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:letterSpacing="0.08"
                        android:text="@string/milestones_label"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_badge"
                        android:textStyle="bold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        app:dividerColor="@color/divider" />

                    <LinearLayout
                        android:id="@+id/milestone1Row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/milestone_1"
                            android:src="@drawable/ic_checkbox_checked" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvMilestone1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:text="@string/milestone_1"
                            android:textColor="@color/milestone_text_done"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/milestone2Row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/milestone_2"
                            android:src="@drawable/ic_checkbox_unchecked" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvMilestone2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:text="@string/milestone_2"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/milestone3Row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/milestone_3"
                            android:src="@drawable/ic_checkbox_unchecked" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvMilestone3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:text="@string/milestone_3"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
