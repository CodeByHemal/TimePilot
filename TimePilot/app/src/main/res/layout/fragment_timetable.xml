<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/timetableScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ===================================================== -->
        <!-- TOP BAR — Avatar  |  "The Scholarly Atelier"           -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/topBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- User Avatar using ShapeableImageView (Material3) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgTimetableAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:src="@drawable/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/purple_light"
                app:strokeWidth="2dp" />

            <!-- App brand name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBrandName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:text="@string/the_scholarly_atelier"
                android:textColor="@color/brand_text"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- HERO SECTION — "Weekly  Itinerary"                     -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTimetableHeroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/timetable_hero_title"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTimetableHeroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/timetable_hero_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- DAY SELECTOR — MON  TUE  WED  THU  FRI                -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/daySelectorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- MON 12 — Selected -->
            <LinearLayout
                android:id="@+id/dayMon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_day_pill_selected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayMonLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_mon"
                    android:textColor="@color/day_selected_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayMonDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/date_12"
                    android:textColor="@color/day_selected_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="0dp" />

            <!-- TUE 13 — Unselected -->
            <LinearLayout
                android:id="@+id/dayTue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_day_pill_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayTueLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_tue"
                    android:textColor="@color/day_label_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayTueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/date_13"
                    android:textColor="@color/day_unselected_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="0dp" />

            <!-- WED 14 — Unselected -->
            <LinearLayout
                android:id="@+id/dayWed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_day_pill_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayWedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_wed"
                    android:textColor="@color/day_label_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayWedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/date_14"
                    android:textColor="@color/day_unselected_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="0dp" />

            <!-- THU 15 — Unselected -->
            <LinearLayout
                android:id="@+id/dayThu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_day_pill_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayThuLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_thu"
                    android:textColor="@color/day_label_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayThuDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/date_15"
                    android:textColor="@color/day_unselected_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="0dp" />

            <!-- FRI 16 — Unselected -->
            <LinearLayout
                android:id="@+id/dayFri"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_day_pill_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayFriLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_fri"
                    android:textColor="@color/day_label_text"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvDayFriDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/date_16"
                    android:textColor="@color/day_unselected_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===================================================== -->
        <!-- CLASS CARD 1 — Advanced Epistemology & Logic           -->
        <!-- ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardClass1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <!-- Row: CORE MODULE chip + Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- CORE MODULE Chip (Material3) -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCoreModule"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/chip_core_module"
                        android:textColor="@color/chip_core_text"
                        android:textSize="@dimen/text_badge"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/chip_core_bg"
                        app:chipCornerRadius="@dimen/radius_sm"
                        app:chipMinHeight="24dp"
                        app:chipMinTouchTargetSize="0dp"
                        app:chipStrokeWidth="0dp"
                        tools:ignore="TouchTargetSizeCheck" />

                    <View
                        android:layout_width="@dimen/spacing_sm"
                        android:layout_height="0dp" />

                    <!-- Clock icon + time text -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_clock_outline"
                        android:contentDescription="@string/class_1_time" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvClass1Time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/class_1_time"
                        android:textColor="@color/class_time_text"
                        android:textSize="@dimen/text_caption" />

                </LinearLayout>

                <!-- Class Title -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvClass1Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/class_1_name"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

                <!-- Instructor + Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Instructor -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_person"
                        android:contentDescription="@string/class_1_instructor" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvClass1Instructor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/class_1_instructor"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body" />

                    <View
                        android:layout_width="@dimen/spacing_lg"
                        android:layout_height="0dp" />

                    <!-- Location -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location_pin"
                        android:contentDescription="@string/class_1_location" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvClass1Location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/class_1_location"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body" />

                </LinearLayout>

                <!-- Action Buttons Row: Notes + More -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Notes icon button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClass1Notes"
                        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/notes_action"
                        app:icon="@drawable/ic_notes"
                        app:iconTint="@color/text_secondary"
                        app:backgroundTint="@color/icon_button_bg" />

                    <View
                        android:layout_width="@dimen/spacing_sm"
                        android:layout_height="0dp" />

                    <!-- More options icon button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClass1More"
                        style="?attr/materialIconButtonFilledStyle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/more_options"
                        app:icon="@drawable/ic_more_vert"
                        app:iconTint="@color/text_secondary"
                        app:backgroundTint="@color/icon_button_bg" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
