<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Big faint circle (Outer) -->
    <item>
        <shape android:shape="oval">
            <size android:width="300dp" android:height="300dp" />
            <stroke android:width="1dp" android:color="#1A6C3CE1" android:dashWidth="4dp" android:dashGap="4dp" />
        </shape>
    </item>
    
    <!-- Medium faint circle -->
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A6C3CE1" android:dashWidth="4dp" android:dashGap="4dp" />
        </shape>
    </item>

    <!-- Inner faint circle -->
    <item android:top="40dp" android:bottom="40dp" android:left="40dp" android:right="40dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A6C3CE1" android:dashWidth="4dp" android:dashGap="4dp" />
        </shape>
    </item>
</layer-list>
